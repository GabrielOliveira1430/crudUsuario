generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 🔐 ENUM DE ROLES
enum Role {
  USER
  ADMIN
}

// 💰 PLANOS
enum Plan {
  FREE
  PRO
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  password String
  role     Role    @default(USER)
  isActive Boolean @default(true)

  // 💰 PLANO DO USUÁRIO
  plan Plan @default(FREE)

  // 🔐 Segurança
  loginAttempts Int       @default(0)
  lockUntil     DateTime?

  // 🛡 Monitoramento
  lastLoginIp   String?
  lastUserAgent String?

  // 🔐 2FA
  twoFactorCode    String?
  twoFactorExpires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 🔗 RELACIONAMENTOS
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  auditLogs           AuditLog[]
  usages              Usage[]
  numberHistory       NumberHistory[]

  // 🆕 SONHOS (analytics)
  dreamWords DreamWord[]

  @@map("users")
}

model RefreshToken {
  id    Int    @id @default(autoincrement())
  token String @unique

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id    Int    @id @default(autoincrement())
  token String @unique

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

// 🔐 PERMISSÕES
model Permission {
  id   Int    @id @default(autoincrement())
  name String @unique

  roles RolePermission[]

  createdAt DateTime @default(now())

  @@map("permissions")
}

// 🔗 RELAÇÃO ROLE ↔ PERMISSION
model RolePermission {
  id Int @id @default(autoincrement())

  role         Role
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
  @@map("role_permissions")
}

// 🧾 AUDITORIA
model AuditLog {
  id Int @id @default(autoincrement())

  userId   Int?
  action   String
  entity   String
  entityId Int?
  metadata Json?

  ip        String?
  userAgent String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// 📊 USO (RATE LIMIT / CONTROLE)
model Usage {
  id     Int      @id @default(autoincrement())
  userId Int
  date   DateTime
  count  Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("usages")
}

// 🔢 HISTÓRICO DE NÚMEROS
model NumberHistory {
  id Int @id @default(autoincrement())

  userId Int
  numbers String[]

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("number_history")
}

// 🆕 ANALYTICS DE SONHOS
model DreamWord {
  id Int @id @default(autoincrement())

  userId Int
  word   String
  count  Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, word])
  @@index([userId])
  @@map("dream_words")
}

// ==========================================
// 🧠 AI LEARNING MEMORY
// ==========================================

model StrategyLearning {

  id Int @id @default(autoincrement())

  // nome da strategy
  name String @unique

  // peso adaptativo
  weight Float @default(1)

  // total de acertos
  hits Int @default(0)

  // total de execuções
  runs Int @default(0)

  // score evolutivo
  score Float @default(0)

  // taxa de sobrevivência
  survivalRate Float @default(1)

  // espécie da strategy
  species String?

  // status
  active Boolean @default(true)

  // metadata futura
  metadata Json?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([name])

  @@index([active])

  @@map("strategy_learning")
}