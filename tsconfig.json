{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "types": ["node", "jest"],

    "typeRoots": ["./node_modules/@types", "./src/@types"]
  },
  "include": ["src", "prisma"],
  "exclude": ["node_modules", "dist", "**/__tests__"]
}